# AI Worker Environment Configuration
# Standardized for V-RAG System

# PostgreSQL
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=ai_user
PG_PASSWORD=ai_password_123
PG_DB=cognitive_db

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Qdrant
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333

# Neo4j
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ai_neo4j_password

# Ollama (AI Model)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=gemma3:4b
OLLAMA_EMBED_MODEL=embeddinggemma

# Logging
LOG_LEVEL=info
LOG_FILE=log_worker.txt

# Environment
NODE_ENV=dev
