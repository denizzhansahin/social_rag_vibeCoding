# AI Worker Environment Configuration
# Copy to .env and update for production

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=ai_user
PG_PASSWORD=CHANGE_ME_STRONG_PASSWORD_123!
PG_DB=cognitive_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_NEO4J_STRONG_PASSWORD!

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=gemma3:4b
OLLAMA_EMBED_MODEL=embeddinggemma

# Logging
LOG_LEVEL=info
LOG_FILE=log_worker.txt

# Production
NODE_ENV=production
